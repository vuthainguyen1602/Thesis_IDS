# ==============================================================================
# Raspberry Pi Edge IDS - Environment Variables
# Copy this file to .env and update values accordingly.
# ==============================================================================
#
# SPLIT DEPLOYMENT:
#   - Mac/PC: runs Docker (Kafka, PostgreSQL, InfluxDB, Grafana)
#   - Raspberry Pi: runs the IDS pipeline only
#   → Replace "localhost" with the Mac's IP (e.g. 192.168.1.225)
#
# ==============================================================================

# --- Kafka ---
# If running on RPi: replace with the Mac's IP (e.g. 192.168.1.225:9092)
KAFKA_BOOTSTRAP_SERVERS=192.168.1.225:9092
KAFKA_TOPIC=ids-network-flow
KAFKA_GROUP_ID=ids-edge-consumer

# --- Model ---
# MODEL_PATH=./model/ids_model.pkl
# SCALER_PATH=./model/scaler.pkl
# FEATURES_PATH=./model/feature_columns.json

# --- PostgreSQL ---
# If running on RPi: replace with the Mac's IP
POSTGRES_HOST=192.168.1.225
POSTGRES_PORT=5433
POSTGRES_DB=ids_edge
POSTGRES_USER=ids
POSTGRES_PASSWORD=ids_password

# --- InfluxDB ---
# If running on RPi: replace with the Mac's IP
INFLUXDB_URL=http://192.168.1.225:8086
INFLUXDB_TOKEN=ids-edge-token
INFLUXDB_ORG=thesis
INFLUXDB_BUCKET=ids_metrics


# --- Email Alert (Mailtrap SMTP) ---
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_username
SMTP_PASSWORD=your_mailtrap_password
ALERT_EMAIL_FROM=ids-alert@raspberry-pi.local
ALERT_EMAIL_TO=admin@example.com

# --- Webhook (Slack) ---
WEBHOOK_URL=https://hooks.slack.com/services/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

# --- Data Sender ---
DATA_CSV_PATH=/path/to/roedunet-simargl2021
SEND_RATE=60

# --- Edge Pipeline ---
EDGE_BATCH_SIZE=20

# --- Performance ---
METRICS_PUSH_INTERVAL=10
ALERT_COOLDOWN=60
